{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "collection.schema.json",
  "title": "Collection",
  "type": "object",
  "required": ["mission_id", "status", "expected", "received", "missing"],
  "additionalProperties": true,
  "properties": {
    "mission_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["OPEN", "CLOSED"]
    },
    "expected": {
      "type": "array",
      "items": {"type": "string"}
    },
    "received": {
      "type": "array",
      "items": {"type": "string"}
    },
    "missing": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
