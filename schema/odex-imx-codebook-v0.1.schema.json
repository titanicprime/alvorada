{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schema/odex-imx-codebook-v0.1.schema.json",
  "type": "object",
  "required": [
    "codebook_id",
    "dictionary_version",
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "codebook_id": {
      "type": "string",
      "minLength": 1
    },
    "dictionary_version": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[0-9A-Fa-f]{2,4}$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
